@import "tailwindcss";

/* 暗色主题通过 .dark 类触发(挂在 <html>) */
@custom-variant dark (&:where(.dark, .dark *));

/*
 * 设计 token —— 语义化颜色变量,亮/暗双套。
 * 组件统一用 var(--xxx) 或 Tailwind 的 bg-[--xxx],不硬编码颜色。
 */
:root {
  --bg: #f1f5f9;          /* 页面底色 slate-100 */
  --surface: #ffffff;     /* 卡片/面板 */
  --surface-hover: #f8fafc;
  --border: #e2e8f0;      /* slate-200 */
  --text: #0f172a;        /* slate-900 */
  --text-muted: #64748b;  /* slate-500 */
  --primary: #6366f1;     /* indigo-500 */
  --primary-hover: #4f46e5;

  /* 状态色(6 态) */
  --status-planning: #94a3b8;
  --status-todo: #3b82f6;
  --status-dispatched: #f59e0b;
  --status-review: #a855f7;
  --status-done: #22c55e;
  --status-blocked: #ef4444;

  /* 优先级色 */
  --priority-p0: #ef4444;
  --priority-p1: #f59e0b;
  --priority-p2: #94a3b8;
}

.dark {
  --bg: #0f172a;          /* slate-900 */
  --surface: #1e293b;     /* slate-800 */
  --surface-hover: #334155;
  --border: #334155;      /* slate-700 */
  --text: #f1f5f9;        /* slate-100 */
  --text-muted: #94a3b8;  /* slate-400 */
  --primary: #818cf8;     /* indigo-400 */
  --primary-hover: #a5b4fc;

  --status-planning: #64748b;
  --status-todo: #60a5fa;
  --status-dispatched: #fbbf24;
  --status-review: #c084fc;
  --status-done: #4ade80;
  --status-blocked: #f87171;

  --priority-p0: #f87171;
  --priority-p1: #fbbf24;
  --priority-p2: #64748b;
}

html,
body,
#root {
  height: 100%;
  margin: 0;
}

body {
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto,
    "Helvetica Neue", Arial, sans-serif;
  background-color: var(--bg);
  color: var(--text);
}

/* 自定义滚动条 */
::-webkit-scrollbar {
  width: 8px;
  height: 8px;
}
::-webkit-scrollbar-thumb {
  background: var(--border);
  border-radius: 4px;
}
