{
  "manifest_version": 3,
  "name": "AI Task Flow 网页剪藏",
  "version": "0.1.0",
  "description": "抓取网页内容与图片，AI 拆解成任务草案，侧边栏确认后建到 AI Task Flow 看板。",
  "permissions": ["sidePanel", "activeTab", "storage", "scripting", "tabs"],
  "host_permissions": ["http://localhost:3000/*"],
  "optional_host_permissions": ["http://*/*", "https://*/*"],
  "background": { "service_worker": "src/background/index.ts", "type": "module" },
  "side_panel": { "default_path": "src/sidepanel/index.html" },
  "action": { "default_title": "打开 AI Task Flow 剪藏侧栏" },
  "content_scripts": [
    {
      "matches": ["https://*.invalid/"],
      "js": ["src/content/clip.ts"],
      "run_at": "document_idle"
    }
  ]
}
