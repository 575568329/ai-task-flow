{
  "name": "ai-task-flow",
  "version": "0.2.0",
  "private": true,
  "workspaces": [
    "shared",
    "backend",
    "frontend",
    "cli",
    "extension"
  ],
  "scripts": {
    "dev": "powershell -ExecutionPolicy Bypass -File scripts/dev.ps1",
    "dev:bash": "bash scripts/dev.sh",
    "dev:concurrently": "concurrently --raw --kill-others-on-fail -n shared,backend,frontend -c blue,green,magenta \"npm run dev:shared\" \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:shared": "cd shared && npm run build:watch",
    "dev:backend": "cd backend && npm run dev",
    "dev:frontend": "cd frontend && npm run dev",
    "cleanup": "powershell -ExecutionPolicy Bypass -File scripts/cleanup.ps1",
    "build": "npm run build:shared && npm run build:backend && npm run build:frontend",
    "build:shared": "cd shared && npm run build",
    "build:backend": "cd backend && npm run build",
    "build:frontend": "cd frontend && npm run build",
    "dev:extension": "cd extension && npm run dev",
    "build:extension": "cd extension && npm run build",
    "start": "node cli/bin/ai-task-flow.js",
    "setup:mcp": "node scripts/setup-mcp.mjs"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "concurrently": "^8.2.2"
  }
}
